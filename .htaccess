# Hostinger/Apache static site settings for ThorDad

# Security + MIME defaults
Options -Indexes
AddDefaultCharset UTF-8
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Route the Hospice Roadmap lab folder directly to its landing page.
  RewriteRule ^labs/hospice-roadmap/?$ /labs/hospice-roadmap/index.html [L]

  # Route extensionless URLs to HTML pages if they exist.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)$ $1.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Always fetch the latest HTML documents.
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Cache static assets for faster loads.
  <FilesMatch "\.(css|js|png|jpg|jpeg|gif|svg|webp|ico)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
</IfModule>
